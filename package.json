{
  "name": "kittyscript",
  "displayName": "KittyScript",
  "description": "KittyScript language support — JS without declaration order worries 🐱",
  "version": "0.1.0",
  "publisher": "kittyscript",
  "engines": { "vscode": "^1.80.0" },
  "categories": ["Programming Languages"],
  "icon": "icon.png",
  "activationEvents": ["onLanguage:kittyscript"],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "kittyscript",
        "aliases": ["KittyScript", "ks"],
        "extensions": [".kss"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icon.png",
          "dark": "./icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "kittyscript",
        "scopeName": "source.kss",
        "path": "./syntaxes/kittyscript.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "kittyscript.compile",
        "title": "KittyScript: Compile current file"
      },
      {
        "command": "kittyscript.compileAll",
        "title": "KittyScript: Compile all .kss files in workspace"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "kittyscript.compile",
          "when": "resourceExtname == .kss",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "KittyScript",
      "properties": {
        "kittyscript.compileOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically compile .kss files on save"
        },
        "kittyscript.outputDir": {
          "type": "string",
          "default": "",
          "description": "Output directory for compiled JS files (empty = same as source)"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -watch -p tsconfig.json",
    "package": "vsce package"
  },
  "dependencies": {
    "kittyscript": "file:../compiler"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.0.0"
  }
}
